cabal-version: 2.4
name:          opencode-example
version:       0.1.0.0
license:       MIT
copyright:     2026 Sridhar Ratnakumar
maintainer:    srid@srid.ca
author:        Sridhar Ratnakumar
category:      Web
synopsis:      Example program using the OpenCode Haskell client

common shared
  ghc-options:
    -Wall -Wincomplete-record-updates -Wincomplete-uni-patterns
    -Wmissing-deriving-strategies -Wunused-foralls -Wunused-foralls
    -fprint-explicit-foralls -fprint-explicit-kinds -Werror

  mixins:
    base hiding (Prelude),
    relude (Relude as Prelude, Relude.Container.One),
    relude

  default-extensions:
    DataKinds
    DerivingStrategies
    DerivingVia
    DuplicateRecordFields
    LambdaCase
    MultiWayIf
    NoStarIsType
    OverloadedRecordDot
    OverloadedStrings
    StrictData
    TypeFamilies
    ViewPatterns

  build-depends:
    , aeson
    , base    >=4   && <5
    , relude  >=1.0

  default-language:   GHC2021

common exe-shared
  ghc-options: -threaded -rtsopts -with-rtsopts=-N

executable opencode-example
  import:         shared, exe-shared
  main-is:        Main.hs
  build-depends:
    , base
    , opencode
    , relude
    , text
    , with-utf8

  hs-source-dirs: src
